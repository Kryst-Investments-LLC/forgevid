# ==========================================================
# ForgeVid Environment Configuration
# ==========================================================
# Copy this file to .env and fill in real values.
# NEVER commit .env with real secrets.
# For production, use a secrets manager (Vault, Doppler, AWS SM).
# ==========================================================

# Database
DATABASE_URL="postgresql://username:password@localhost:5432/forgevid?schema=public"

# NextAuth.js
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""  # Generate: openssl rand -base64 32
NEXT_PUBLIC_BETA_MODE="false"

# Split deployment (Vercel frontend -> Railway backend)
BACKEND_API_ORIGIN=""
NEXT_PUBLIC_COLLABORATION_URL=""
ALLOWED_ORIGINS="http://localhost:3000"

# Beta access control
BETA_MODE="false"
BETA_ALLOWED_EMAILS=""
BETA_INVITE_CODES=""

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# AI Services
OPENAI_API_KEY=""
# Deprecated alias, still honoured so existing deployments (docker-compose.prod.yml,
# docs/USAGE-GUIDE.md) keep working. Set OPENAI_API_KEY only; do not set both.
# OPENAI_SECRET_KEY=""
ELEVENLABS_API_KEY=""
# AI avatar videos (HeyGen). Pro-plan feature; routes return 503 without it.
HEYGEN_API_KEY=""

# Media Storage
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Payment Processing (use sk_test_ for development)
STRIPE_PUBLIC_KEY=""
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Redis Cache
REDIS_URL="redis://localhost:6379"
REDIS_PASSWORD=""

# Monitoring & Analytics
SENTRY_DSN=""

# PostHog Analytics
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"
POSTHOG_HOST="https://us.i.posthog.com"

# AI Video Generation (Replicate)
REPLICATE_API_TOKEN=""

# CDN (CloudFront or Cloudflare)
CDN_BASE_URL=""  # e.g. https://cdn.forgevid.com

# Email Service
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""

# Feature Flags
ENABLE_AI_FEATURES="true"
ENABLE_COLLABORATION="true"
ENABLE_ANALYTICS="true"
ENABLE_PAYMENTS="true"

# Security
ENCRYPTION_KEY=""    # Generate: openssl rand -base64 32
JWT_SECRET=""        # Generate: openssl rand -base64 32
CSRF_SECRET=""       # Generate: openssl rand -base64 32

# Storage Limits
MAX_FILE_SIZE="100MB"
MAX_VIDEO_LENGTH="600"
MAX_STORAGE_PER_USER="10GB"

# Rate Limiting
RATE_LIMIT_WINDOW_MS="900000"
RATE_LIMIT_MAX_REQUESTS="100"

# Logging
LOG_LEVEL="info"       # error, warn, info, debug
LOG_TO_FILE="false"    # Set true for non-containerized deployments

# External APIs
PEXELS_API_KEY=""
RUNWAY_API_KEY=""

# Rendering
# Font used to burn in captions/text overlays. Optional: common system paths are
# probed automatically (the Docker image installs ttf-dejavu). Set this only if
# ffmpeg reports "Cannot find a valid font" or you want a specific typeface.
CAPTION_FONT_FILE=""

# Environment
NODE_ENV="development"
PORT="3000"

# Enable headless-browser fallback for JS-only pages in /api/site-brief.
# Requires the optional playwright package + chromium. Off by default.
HEADLESS_BROWSER=""

# ============================================================================
# LAUNCH-CRITICAL (Tier 1) — the app reads these but the block above omitted them
# ============================================================================

# Stripe Products/Prices. Create three recurring Prices in the Stripe dashboard
# and paste their price IDs here. Checkout maps plan -> price via these vars,
# so billing silently does nothing until they are set.
STRIPE_STARTER_PRICE_ID=""
STRIPE_PRO_PRICE_ID=""
STRIPE_ENTERPRISE_PRICE_ID=""

# Legal / company identity — fills the ToS, Privacy, and Refund pages and the
# checkout consent line. All are NEXT_PUBLIC (rendered in the browser).
NEXT_PUBLIC_COMPANY_NAME="Kryst Investments LLC"
NEXT_PUBLIC_COMPANY_ADDRESS=""                         # your real business address
NEXT_PUBLIC_WEBSITE_URL="https://yourdomain.com"
NEXT_PUBLIC_LEGAL_EMAIL="legal@yourdomain.com"
NEXT_PUBLIC_PRIVACY_EMAIL="privacy@yourdomain.com"
NEXT_PUBLIC_BILLING_EMAIL="billing@yourdomain.com"
NEXT_PUBLIC_DPO_EMAIL="privacy@yourdomain.com"
NEXT_PUBLIC_DMCA_EMAIL="dmca@yourdomain.com"           # your registered DMCA agent
NEXT_PUBLIC_GOVERNING_STATE="Florida"
NEXT_PUBLIC_ARBITRATION_VENUE="Miami-Dade County, Florida"
NEXT_PUBLIC_LEGAL_UPDATED="July 20, 2026"

# Content moderation. Keep false: if the image moderation call errors, the image
# is BLOCKED rather than allowed through (CSAM-safe fail-closed).
MODERATION_IMAGES_FAIL_OPEN="false"

# Browser-side error capture (server/worker use SENTRY_DSN above).
NEXT_PUBLIC_SENTRY_DSN=""
