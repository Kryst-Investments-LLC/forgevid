# next-auth / @auth/core declare a peerOptional on nodemailer that conflicts
# with the version the security patch pinned. npm ci (Railway's install step)
# fails ERESOLVE on that conflict by default; matching the local resolution
# here lets the deploy build. Safe: nodemailer is a peerOPTIONAL, only used by
# the email path, which is exercised and working.
legacy-peer-deps=true
