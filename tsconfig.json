{
  "compilerOptions": {
  "lib": ["dom", "dom.iterable", "esnext"],
  "downlevelIteration": true,
  "allowJs": true,
  "target": "ES2022",
  "skipLibCheck": true,
  "strict": true,
  "noEmit": false,
  "outDir": "./dist",
  "esModuleInterop": true,
  "module": "ES2022",
  "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
