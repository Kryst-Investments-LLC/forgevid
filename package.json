{
  "name": "forgevid",
  "version": "1.0.0",
  "private": true,
  "description": "AI-Powered Video Creation Platform - Production Ready",
  "scripts": {
    "build": "next build",
    "dev": "node server.js",
    "worker": "tsx workers/video-worker.ts",
    "verify:export": "tsx scripts/verify-export.ts",
    "verify:generate": "tsx scripts/verify-generate.ts",
    "verify:e2e": "tsx scripts/verify-e2e.ts",
    "verify:e2e:db": "bash scripts/run-e2e-with-db.sh",
    "verify:providers": "tsx scripts/verify-providers.ts",
    "verify:site": "tsx scripts/verify-site.ts",
    "verify:proxy": "tsx scripts/verify-proxy.ts",
    "db:local": "bash scripts/db-local.sh start",
    "db:local:stop": "bash scripts/db-local.sh stop",
    "lint": "next lint",
    "start": "next start",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:unit": "jest --testPathPattern=__tests__ --coverage",
    "test:integration": "jest --testPathPattern=__tests__/api --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:load": "artillery run artillery/load-test.yml",
    "test:security": "zap-baseline.py -t http://localhost:3000 -J security-report.json",
    "test:security:custom": "npx ts-node scripts/security-test.ts",
    "test:security:prod": "npx ts-node scripts/security-test.ts https://yourdomain.com",
    "test:api:security": "npx ts-node scripts/api-security-test.ts",
    "test:api:security:prod": "npx ts-node scripts/api-security-test.ts https://yourdomain.com",
    "test:all": "powershell -ExecutionPolicy Bypass -File scripts/run-tests.ps1",
    "test:ci": "npm run test:unit && npm run test:integration && npm run test:e2e",
    "type-check": "tsc --noEmit",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "db:seed": "tsx prisma/seed.ts",
    "templates:seed": "tsx scripts/seed-templates.ts",
    "templates:seed-large": "tsx scripts/seed-templates-large.ts",
    "db:migrate": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:reset": "prisma migrate reset",
    "db:studio": "prisma studio",
    "db:backup": "node scripts/backup-db.js",
    "monitor:health": "curl http://localhost:3000/api/health",
    "monitor:metrics": "curl http://localhost:3000/api/metrics",
    "security:audit": "npm audit",
    "security:fix": "npm audit fix",
    "performance:lighthouse": "lighthouse http://localhost:3000 --output=html --output-path=./reports/lighthouse-report.html",
    "performance:budget": "lighthouse http://localhost:3000 --budget-path=./lighthouse-budget.json --output=html",
    "collaboration:dev": "node scripts/start-collaboration-server.js",
    "collaboration:dev:memory": "node scripts/start-without-redis.js",
    "collaboration:start": "cd server && npm start",
    "dev:full": "concurrently \"npm run dev\" \"npm run collaboration:dev\"",
    "dev:memory": "concurrently \"npm run dev\" \"npm run collaboration:dev:memory\"",
    "db:deploy": "prisma migrate deploy",
    "db:push": "prisma db push",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "build:analyze": "ANALYZE=true npm run build",
    "docker:build": "docker build -t forgevid .",
    "docker:run": "docker run -p 3000:3000 forgevid",
    "docker:dev": "docker-compose up -d",
    "docker:prod": "docker-compose -f docker-compose.prod.yml up -d",
    "validate": "npm run type-check && npm run lint && npm run test"
  },
  "keywords": [
    "video-creation",
    "ai-powered",
    "video-editing",
    "collaboration",
    "nextjs",
    "typescript",
    "production-ready"
  ],
  "author": "Kryst Investments LLC",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/krystinvestments/forgevid.git"
  },
  "bugs": {
    "url": "https://github.com/krystinvestments/forgevid/issues"
  },
  "homepage": "https://forgevid.com",
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.0",
    "@cloudinary/url-gen": "^1.22.0",
    "@dnd-kit/core": "^6.3.1",
