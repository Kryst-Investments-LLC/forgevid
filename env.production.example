# ForgeVid Production Environment Configuration
# Copy this file to .env.local and fill in your actual values

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# PostgreSQL connection string
DATABASE_URL="postgresql://username:password@localhost:5432/forgevid_prod"

# =============================================================================
# AUTHENTICATION & SECURITY
# =============================================================================
# NextAuth.js secret (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET="your-super-secret-key-here-change-this-in-production"

# NextAuth.js URL (your domain)
NEXTAUTH_URL="https://forgevid.com"

# JWT secret for API authentication (generate with: openssl rand -base64 32)
JWT_SECRET="your-jwt-secret-here-change-this-in-production"

# =============================================================================
# OAUTH PROVIDERS
# =============================================================================
# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# =============================================================================
# AI SERVICES
# =============================================================================
# OpenAI API Key
OPENAI_SECRET_KEY="sk-your-openai-api-key"

# ElevenLabs API Key
ELEVENLABS_API_KEY="your-elevenlabs-api-key"

# =============================================================================
# MEDIA STORAGE
# =============================================================================
# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME="your-cloudinary-cloud-name"
CLOUDINARY_API_KEY="your-cloudinary-api-key"
CLOUDINARY_API_SECRET="your-cloudinary-api-secret"

# AWS S3 Configuration (alternative to Cloudinary)
AWS_ACCESS_KEY_ID="your-aws-access-key"
AWS_SECRET_ACCESS_KEY="your-aws-secret-key"
AWS_REGION="us-east-1"
AWS_S3_BUCKET="your-s3-bucket-name"

# =============================================================================
# PAYMENT PROCESSING
# =============================================================================
# Stripe Configuration
STRIPE_PUBLIC_KEY="pk_test_your-stripe-public-key"
STRIPE_SECRET_KEY="sk_test_your-stripe-secret-key"
STRIPE_WEBHOOK_SECRET="whsec_your-stripe-webhook-secret"

# =============================================================================
# CACHING & SESSIONS
# =============================================================================
# Redis connection string
REDIS_URL="redis://localhost:6379"

# Redis password (if required)
REDIS_PASSWORD=""

# =============================================================================
# MONITORING & LOGGING
# =============================================================================
# Sentry DSN for error tracking
SENTRY_DSN="https://your-sentry-dsn@sentry.io/project-id"

# Sentry configuration
SENTRY_AUTH_TOKEN="your-sentry-auth-token"
SENTRY_ORG="your-sentry-org"
SENTRY_PROJECT="forgevid"

# =============================================================================
# EMAIL SERVICES
# =============================================================================
# SendGrid API Key
SENDGRID_API_KEY="SG.your-sendgrid-api-key"

# AWS SES Configuration
AWS_SES_REGION="us-east-1"
AWS_SES_FROM_EMAIL="noreply@forgevid.com"

# =============================================================================
# CDN & ASSET DELIVERY
# =============================================================================
# CDN Base URL
CDN_BASE_URL="https://cdn.forgevid.com"

# =============================================================================
# SECURITY & COMPLIANCE
# =============================================================================
# Encryption key for sensitive data
ENCRYPTION_KEY="your-32-character-encryption-key"

# Rate limiting configuration
RATE_LIMIT_WINDOW_MS="900000"
RATE_LIMIT_MAX_REQUESTS="100"

# =============================================================================
# COLLABORATION SERVER
# =============================================================================
# Collaboration server configuration
COLLABORATION_SERVER_PORT="3001"
COLLABORATION_SERVER_URL="wss://forgevid.com"

# =============================================================================
# MONITORING & OBSERVABILITY
# =============================================================================
# Grafana configuration
GRAFANA_PASSWORD="admin-password-change-this"

# Prometheus configuration
PROMETHEUS_RETENTION="200h"

# =============================================================================
# DEVELOPMENT & DEBUGGING
# =============================================================================
# Environment
NODE_ENV="production"

# Debug mode (set to false in production)
DEBUG="false"

# Log level (error, warn, info, debug)
LOG_LEVEL="info"

# =============================================================================
# BACKUP & DISASTER RECOVERY
# =============================================================================
# Backup configuration
BACKUP_S3_BUCKET="your-backup-bucket"
BACKUP_RETENTION_DAYS="30"

# =============================================================================
# PERFORMANCE & SCALING
# =============================================================================
# Auto-scaling configuration
MIN_INSTANCES="2"
MAX_INSTANCES="20"
SCALE_UP_THRESHOLD="70"
SCALE_DOWN_THRESHOLD="30"

# Cache TTL (in seconds)
CACHE_TTL_USER="900"
CACHE_TTL_VIDEO="1800"
CACHE_TTL_TEMPLATE="3600"

# =============================================================================
# FEATURE FLAGS
# =============================================================================
# Enable/disable features
FEATURE_AI_GENERATION="true"
FEATURE_COLLABORATION="true"
FEATURE_ANALYTICS="true"
FEATURE_PAYMENTS="true"

# =============================================================================
# COMPLIANCE & DATA PROTECTION
# =============================================================================
# GDPR compliance
GDPR_ENABLED="true"
DATA_RETENTION_DAYS="2555"  # 7 years

# SOC2 compliance
SOC2_ENABLED="true"
AUDIT_LOGGING="true"

# HIPAA compliance (if applicable)
HIPAA_ENABLED="false"

# PCI DSS compliance
PCI_DSS_ENABLED="true"

# =============================================================================
# EXTERNAL SERVICES
# =============================================================================
# Webhook URLs
WEBHOOK_URL="https://forgevid.com/api/webhooks"

# API rate limits
API_RATE_LIMIT="1000"
API_RATE_WINDOW="3600"  # 1 hour

# =============================================================================
# DOCKER & CONTAINERIZATION
# =============================================================================
# Docker configuration
DOCKER_REGISTRY="your-registry.com"
DOCKER_IMAGE_TAG="latest"

# =============================================================================
# SSL & CERTIFICATES
# =============================================================================
# SSL configuration
SSL_CERT_PATH="/etc/ssl/certs/your-domain.crt"
SSL_KEY_PATH="/etc/ssl/private/your-domain.key"

# =============================================================================
# CUSTOM CONFIGURATION
# =============================================================================
# Add any custom environment variables here
CUSTOM_FEATURE_ENABLED="false"
CUSTOM_API_KEY=""
CUSTOM_WEBHOOK_URL=""

# =============================================================================
# NOTES
# =============================================================================
# 1. Never commit this file with real secrets to version control
# 2. Use a secrets management system in production
# 3. Rotate secrets regularly
# 4. Use environment-specific configurations
# 5. Monitor for exposed secrets in logs and error messages
# 6. Use strong, unique passwords and API keys
# 7. Enable two-factor authentication where possible
# 8. Regularly audit access to these credentials